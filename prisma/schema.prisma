generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
}

enum Language {
  EN
  AR
}

enum Role {
  CUSTOMER
  DRIVER
  VENDOR_MEMBER
  ADMIN
  SUPER_ADMIN
}

enum Permission {
  MANAGE_ORDERS
  MANAGE_PRODUCTS
  MANAGE_VENDORS
  MANAGE_DRIVERS
  MANAGE_CUSTOMERS
  MANAGE_TICKETS
  MANAGE_CONVERSATIONS
  VIEW_STATISTICS
  MANAGE_SETTINGS
  MANAGE_USERS
  VIEW_FINANCIALS
  MANAGE_FINANCE
  MANAGE_PROMOTIONS
  VIEW_AUDIT_LOGS
}

enum ConversationStatus {
  OPEN
  CLOSED
  ARCHIVED
}

enum NotificationType {
  ORDER_UPDATE
  CHAT_MESSAGE
  PROMOTION
  SYSTEM
  PAYMENT
  TICKET_UPDATE
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  LOCATION
  SYSTEM
}

enum ConversationType {
  ORDER
  SUPPORT
}

enum VendorStatus {
  CLOSED
  OPEN
  PAUSED
  SUSPENDED
}

enum VendorMemberRole {
  OWNER
  MANAGER
  STAFF
}

enum VehicleType {
  BICYCLE
  MOTORCYCLE
  CAR
  VAN
}

enum DriverStatus {
  OFFLINE
  ONLINE
  BUSY
  ON_DELIVERY
  ON_BREAK
  SUSPENDED
}

enum DriverShiftStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
  MISSED
}

enum WalletTransactionType {
  DELIVERY_FEE
  CASH_COLLECTED
  CASH_HANDED_TO_VENDOR
  PAYOUT
  PENALTY
  BONUS
  ADJUSTMENT
}

enum VendorTransactionType {
  ORDER_REVENUE
  COMMISSION_DEDUCTION
  CASH_COLLECTED
  PAYOUT
  REFUND
  ADJUSTMENT
}

enum StatisticPeriod {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  LOOKING_FOR_DRIVER
  DRIVER_ASSIGNED
  READY_FOR_PICKUP
  PICKED_UP
  DELIVERED
  CANCELLED
}

enum DispatchStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  MOBILE_WALLET
}

enum PaymentStatus {
  PENDING
  COMPLETED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_USER
  RESOLVED
  CLOSED
}

enum TicketCategory {
  GENERAL
  ORDER_ISSUE
  PAYMENT_ISSUE
  TECHNICAL_ISSUE
  COMPLAINT
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AuditActionType {
  CREATE
  UPDATE
  DELETE
  OTHER
}

model PlatformSetting {
  id String @id @default("default")

  currency              String  @default("EGP")
  defaultCommissionRate Decimal @default(10.00) @db.Decimal(10, 2)
  defaultTaxRate        Decimal @default(14.00) @db.Decimal(10, 2)
  minOrderAmount        Decimal @default(0.00)  @db.Decimal(10, 2)

  baseDeliveryFee       Decimal @default(15.00) @db.Decimal(10, 2)
  pricePerKm            Decimal @default(3.00)  @db.Decimal(10, 2)
  maxDeliveryRadiusKm   Float   @default(15.0)
  driverSearchRadiusKm  Float   @default(5.0)

  autoCancelPendingMins Int     @default(15)
  driverAcceptTimeoutSecs Int   @default(30)

  isMaintenanceMode     Boolean @default(false)

  androidMinVersion     String  @default("1.0.0")
  androidLatestVersion  String  @default("1.0.0")
  androidForceUpdate    Boolean @default(false)
  androidStoreUrl       String?

  iosMinVersion         String  @default("1.0.0")
  iosLatestVersion      String  @default("1.0.0")
  iosForceUpdate        Boolean @default(false)
  iosStoreUrl           String?

  supportEmail          String?
  supportPhone          String?
  supportWhatsapp       String?

  termsUrl              String?
  privacyUrl            String?

  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

model Zone {
  id        String  @id @default(uuid())
  name      String
  nameAr    String?

  boundary  Unsupported("geometry(Polygon, 4326)")

  isActive  Boolean @default(true)

  baseDeliveryFeeOverride Decimal? @db.Decimal(10, 2)
  minOrderAmountOverride  Decimal? @db.Decimal(10, 2)

  orders          Order[]
  vendorBranches  VendorBranch[]
  driverShifts    DriverShift[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([boundary], type: Gist)
  @@map("zones")
}

model User {
  id String @id @default(uuid())

  email    String? @unique
  phone    String? @unique
  password String

  name     String
  role     Role     @default(CUSTOMER)
  title    String?
  titleAr  String?
  permissions Permission[]
  avatar   String?
  language Language @default(EN)

  isEmailVerified Boolean @default(false)
  isPhoneVerified Boolean @default(false)

  isBanned  Boolean @default(false)
  banReason String?

  vendorMemberships VendorMember[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  messages             Message[]
  conversations        ConversationParticipant[]
  devices              Device[]
  sessions             Session[]
  notifications        Notification[]
  notificationSettings NotificationSetting?

  auditLogs AuditLog[]

  createdTickets       SupportTicket[] @relation("TicketCreator")
  assignedTickets      SupportTicket[] @relation("TicketAssignee")

  customer Customer?
  driver   Driver?

  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model Device {
  id         String         @id @default(uuid())
  token      String         @unique
  platform   DevicePlatform
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastActive DateTime       @default(now())

  @@index([userId])
  @@index([userId, platform])
  @@map("devices")
}

model Session {
  id String @id @default(uuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  hashedRt String

  ipAddress String?
  userAgent String?

  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  title   String
  titleAr String?
  body    String?
  bodyAr  String?

  type      NotificationType
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([userId, type])
  @@map("notifications")
}

model NotificationSetting {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  pushEnabled   Boolean @default(true)
  orderUpdates  Boolean @default(true)
  chatMessages  Boolean @default(true)
  promotions    Boolean @default(true)
  system        Boolean @default(true)
  ticketUpdates Boolean @default(true)

  updatedAt DateTime @updatedAt

  @@map("notification_settings")
}

model Conversation {
  id String @id @default(uuid())

  type    ConversationType   @default(ORDER)
  orderId String?
  status  ConversationStatus @default(OPEN)

  vendorId String?
  vendor   Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  supportTicket SupportTicket?

  participants ConversationParticipant[]
  messages     Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([vendorId])
  @@index([createdAt])
  @@map("conversations")
}

model ConversationParticipant {
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  joinedAt   DateTime @default(now())
  lastReadAt DateTime @default(now())

  @@id([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id String @id @default(uuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation(fields: [senderId], references: [id])

  type MessageType @default(TEXT)

  text     String?
  mediaUrl String?
  metadata Json?

  replyToId String?
  replyTo   Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[] @relation("MessageReplies")

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([replyToId])
  @@map("messages")
}

model SupportTicket {
  id           String   @id @default(uuid())
  ticketNumber String   @unique

  subject      String
  description  String?

  status       TicketStatus   @default(OPEN)
  category     TicketCategory @default(GENERAL)
  priority     TicketPriority @default(MEDIUM)

  creatorId    String
  creator      User     @relation("TicketCreator", fields: [creatorId], references: [id])

  assigneeId   String?
  assignee     User?    @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  orderId      String?
  order        Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  vendorId     String?
  vendor       Vendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  conversationId String? @unique
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([creatorId])
  @@index([assigneeId])
  @@index([vendorId])
  @@index([status])
  @@index([orderId])
  @@map("support_tickets")
}

model Customer {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  canOrder   Boolean @default(true)

  addresses Address[]
  carts     Cart[]
  orders    Order[]
  favoriteVendors  FavoriteVendor[]
  favoriteProducts FavoriteProduct[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([deletedAt])
  @@map("customers")
}

model FavoriteVendor {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vendorId   String
  vendor     Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([customerId, vendorId])
  @@index([customerId])
  @@map("favorite_vendors")
}

model FavoriteProduct {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
  @@index([customerId])
  @@map("favorite_products")
}

model Address {
  id      String @id @default(uuid())
  label   String @default("Home")
  address String

  location Unsupported("geometry(Point, 4326)")

  details   String?
  isDefault Boolean @default(false)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([location], type: Gist)
  @@map("addresses")
}

model VendorVertical {
  id        String  @id @default(uuid())
  name      String
  nameAr    String?
  slug      String  @unique
  iconUrl   String?
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  vendors Vendor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("vendor_verticals")
}

model Vendor {
  id String @id @default(uuid())

  members VendorMember[]

  storeName     String
  storeNameAr   String?
  slug          String  @unique
  description   String?
  descriptionAr String?
  logo          String?
  coverImage    String?

  taxId          String?
  commissionRate Decimal @default(10.0)

  status VendorStatus @default(CLOSED)

  walletBalance Decimal @default(0.00) @db.Decimal(10, 2)

  verticalId String
  vertical   VendorVertical @relation(fields: [verticalId], references: [id])

  branches   VendorBranch[]
  categories MenuCategory[]
  products   Product[]
  carts      Cart[]
  orders     Order[]

  walletTransactions VendorWalletTransaction[]
  statistics         VendorStatistic[]
  conversations      Conversation[]

  supportTickets   SupportTicket[]

  favoritedBy      FavoriteVendor[]
  
  auditLogs AuditLog[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([status])
  @@index([verticalId])
  @@index([deletedAt])
  @@map("vendors")
}

model VendorMember {
  id String @id @default(uuid())

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role VendorMemberRole @default(STAFF)

  createdAt DateTime @default(now())

  @@unique([vendorId, userId])
  @@index([userId])
  @@map("vendor_members")
}

model VendorBranch {
  id      String  @id @default(uuid())
  name    String
  nameAr  String?
  address String
  phone   String?
  isOpen  Boolean @default(true)

  location Unsupported("geometry(Point, 4326)")

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  zoneId String?
  zone   Zone?   @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId])
  @@index([zoneId])
  @@index([vendorId, isOpen])
  @@index([location], type: Gist)
  @@map("vendor_branches")
}

model VendorWalletTransaction {
  id String @id @default(uuid())

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  type VendorTransactionType

  amount       Decimal @db.Decimal(10, 2)
  balanceAfter Decimal @db.Decimal(10, 2)

  description String?
  referenceId String?

  createdAt DateTime @default(now())

  @@index([vendorId])
  @@index([orderId])
  @@index([createdAt])
  @@map("vendor_wallet_transactions")
}

model VendorStatistic {
  id String @id @default(uuid())

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  period    StatisticPeriod
  startDate DateTime        @db.Date
  endDate   DateTime        @db.Date

  totalOrders     Int     @default(0)
  totalRevenue    Decimal @default(0.00) @db.Decimal(10, 2)
  totalCommission Decimal @default(0.00) @db.Decimal(10, 2)
  totalTax        Decimal @default(0.00) @db.Decimal(10, 2)

  completedOrders Int    @default(0)
  cancelledOrders Int    @default(0)
  avgPrepTimeMins Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vendorId, period, startDate])
  @@index([vendorId, period])
  @@index([startDate, endDate])
  @@map("vendor_statistics")
}

model AppStatistic {
  id String @id @default(uuid())

  period    StatisticPeriod
  startDate DateTime        @db.Date
  endDate   DateTime        @db.Date

  totalOrders       Int     @default(0)
  totalAdminRevenue Decimal @default(0.00) @db.Decimal(10, 2)
  totalDeliveryFees Decimal @default(0.00) @db.Decimal(10, 2)

  activeCustomers Int @default(0)
  activeDrivers   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([period, startDate])
  @@index([period])
  @@index([startDate, endDate])
  @@map("app_statistics")
}

model MenuCategory {
  id       String @id @default(uuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  name          String
  nameAr        String?
  description   String?
  descriptionAr String?
  sortOrder     Int     @default(0)
  isActive      Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId, isActive])
  @@map("menu_categories")
}

model Product {
  id String @id @default(uuid())

  version Int @default(1)

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  categoryId String?
  category   MenuCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  name          String
  nameAr        String?
  description   String?
  descriptionAr String?
  imageUrl      String?

  hasVariants  Boolean  @default(false)
  basePrice    Decimal? @db.Decimal(10, 2)
  comparePrice Decimal? @db.Decimal(10, 2)
  sku          String?  @unique
  stock        Int?

  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)

  deletedAt DateTime?

  variants     ProductVariant[]
  optionGroups ProductOptionGroup[]
  cartItems    CartItem[]
  orderItems   OrderItem[]

  favoritedBy  FavoriteProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId, isActive])
  @@index([vendorId, isActive, isFeatured])
  @@index([categoryId])
  @@index([deletedAt])
  @@map("products")
}

model ProductVariant {
  id String @id @default(uuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name   String
  nameAr String?
  sku    String? @unique

  basePrice    Decimal  @db.Decimal(10, 2)
  comparePrice Decimal? @db.Decimal(10, 2)

  stock    Int?
  isActive Boolean @default(true)

  version Int @default(1)

  optionGroups ProductOptionGroup[]
  cartItems    CartItem[]
  orderItems   OrderItem[]

  @@index([productId, isActive])
  @@map("product_variants")
}

model ProductOptionGroup {
  id String @id @default(uuid())

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  name   String
  nameAr String?

  isRequired Boolean @default(false)
  minSelect  Int     @default(0)
  maxSelect  Int     @default(1)

  options ProductOption[]

  @@index([productId])
  @@index([variantId])
  @@map("product_option_groups")
}

model ProductOption {
  id String @id @default(uuid())

  groupId String
  group   ProductOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  name   String
  nameAr String?

  priceAdded Decimal @default(0.00) @db.Decimal(10, 2)

  isActive Boolean @default(true)

  cartItemOptions  CartItemOption[]
  orderItemOptions OrderItemOption[]

  @@index([groupId])
  @@map("product_options")
}

model Cart {
  id String @id @default(uuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([customerId, vendorId])
  @@index([customerId])
  @@map("carts")
}

model CartItem {
  id String @id @default(uuid())

  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  quantity       Int     @default(1)
  specialRequest String?

  selectedOptions CartItemOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
  @@map("cart_items")
}

model CartItemOption {
  id String @id @default(uuid())

  cartItemId String
  cartItem   CartItem @relation(fields: [cartItemId], references: [id], onDelete: Cascade)

  optionId String
  option   ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@index([cartItemId])
  @@map("cart_item_options")
}

model Order {
  id          String @id @default(uuid())
  orderNumber String @unique

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  driverId String?
  driver   Driver? @relation(fields: [driverId], references: [id], onDelete: SetNull)

  zoneId String?
  zone   Zone?   @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  driverShiftId String?
  driverShift   DriverShift? @relation(fields: [driverShiftId], references: [id], onDelete: SetNull)

  driverTransactions DriverWalletTransaction[]
  vendorTransactions VendorWalletTransaction[]
  dispatches         OrderDispatch[]

  statusEvents OrderStatusEvent[]

  supportTickets SupportTicket[]

  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)

  deliveryAddress String

  deliveryLocation Unsupported("geometry(Point, 4326)")

  subtotal    Decimal @db.Decimal(10, 2)
  deliveryFee Decimal @db.Decimal(10, 2)
  serviceFee  Decimal @db.Decimal(10, 2)
  tax         Decimal @db.Decimal(10, 2)
  discount    Decimal @default(0.00) @db.Decimal(10, 2)
  grandTotal  Decimal @db.Decimal(10, 2)

  specialRequest    String?
  estimatedPrepTime Int?

  items OrderItem[]

  deletedAt DateTime?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  acceptedAt         DateTime?
  preparedAt         DateTime?
  driverAssignedAt   DateTime?
  pickedUpAt         DateTime?
  actualDeliveryTime DateTime?

  @@index([customerId])
  @@index([vendorId])
  @@index([zoneId])
  @@index([vendorId, status])
  @@index([driverId])
  @@index([status])
  @@index([deletedAt])
  @@index([deliveryLocation], type: Gist)
  @@map("orders")
}

model OrderStatusEvent {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  status    OrderStatus
  note      String?
  createdBy String?

  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
  @@map("order_status_events")
}

model OrderItem {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  productName String
  variantName String?
  unitPrice   Decimal @db.Decimal(10, 2)

  quantity   Int
  totalPrice Decimal @db.Decimal(10, 2)

  specialRequest String?

  selectedOptions OrderItemOption[]

  @@index([orderId])
  @@map("order_items")
}

model OrderItemOption {
  id String @id @default(uuid())

  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  optionId String?
  option   ProductOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  optionName String
  priceAdded Decimal @db.Decimal(10, 2)

  @@index([orderItemId])
  @@map("order_item_options")
}

model Driver {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  avatar        String?
  nationalId    String?
  licenseNumber String?
  vehicleType   VehicleType @default(MOTORCYCLE)
  vehiclePlate  String?

  status DriverStatus @default(OFFLINE)

  currentLocation    Unsupported("geometry(Point, 4326)")?
  lastLocationUpdate DateTime?

  rating      Decimal @default(5.0)
  totalOrders Int     @default(0)

  walletBalance Decimal @default(0.00) @db.Decimal(10, 2)

  walletTransactions DriverWalletTransaction[]
  statistics         DriverStatistic[]
  dispatches         OrderDispatch[]

  version Int @default(1)

  shifts DriverShift[]
  orders Order[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("drivers")
}

model DriverShift {
  id String @id @default(uuid())

  driverId String
  driver   Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  zoneId String?
  zone   Zone?   @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  shiftDate DateTime
  startTime DateTime
  endTime   DateTime

  actualStart DateTime?
  actualEnd   DateTime?

  startingLocation Unsupported("geometry(Point, 4326)")?
  endingLocation   Unsupported("geometry(Point, 4326)")?

  status DriverShiftStatus @default(SCHEDULED)
  orders Order[]

  walletTransactions DriverWalletTransaction[]
  dispatches         OrderDispatch[]

  breakMinutes    Int?
  totalEarnings   Decimal? @db.Decimal(10, 2)
  totalDeliveries Int?

  createdAt DateTime @default(now())

  @@index([driverId])
  @@index([zoneId])
  @@index([driverId, status])
  @@index([shiftDate])
  @@index([status])
  @@index([startingLocation], type: Gist)
  @@index([endingLocation], type: Gist)
  @@map("driver_shifts")
}

model DriverWalletTransaction {
  id String @id @default(uuid())

  driverId String
  driver   Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  driverShiftId String?
  driverShift   DriverShift? @relation(fields: [driverShiftId], references: [id], onDelete: SetNull)

  type         WalletTransactionType
  amount       Decimal               @db.Decimal(10, 2)
  balanceAfter Decimal               @db.Decimal(10, 2)

  description String?
  referenceId String?

  createdAt DateTime @default(now())

  @@index([driverId])
  @@index([orderId])
  @@index([createdAt])
  @@index([driverShiftId])
  @@map("driver_wallet_transactions")
}

model DriverStatistic {
  id String @id @default(uuid())

  driverId String
  driver   Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  period    StatisticPeriod
  startDate DateTime        @db.Date
  endDate   DateTime        @db.Date

  totalOrders     Int     @default(0)
  totalEarnings   Decimal @default(0.00) @db.Decimal(10, 2)
  completedOrders Int     @default(0)
  cancelledOrders Int     @default(0)
  onlineHours     Float?

  totalDispatchesReceived Int @default(0)
  dispatchesAccepted      Int @default(0)
  dispatchesRejected      Int @default(0)
  dispatchesExpired       Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([driverId, period, startDate])
  @@index([driverId, period])
  @@index([startDate, endDate])
  @@map("driver_statistics")
}

model OrderDispatch {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  driverId String
  driver   Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  driverShiftId String?
  driverShift   DriverShift? @relation(fields: [driverShiftId], references: [id], onDelete: SetNull)

  status DispatchStatus @default(PENDING)

  distanceKm        Float?
  estimatedEarnings Decimal? @db.Decimal(10, 2)

  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([driverId])
  @@index([driverShiftId])
  @@index([status])
  @@index([createdAt])
  @@map("order_dispatches")
}

model AuditLog {
  id           String           @id @default(uuid())
  
  userId       String   
  user         User             @relation(fields: [userId], references: [id], onDelete: Restrict)

  vendorId     String?
  vendor       Vendor?          @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  actionType   AuditActionType  @default(OTHER)
  action       String
  
  entityType   String
  entityId     String

  oldValues    Json?
  newValues    Json?

  createdAt    DateTime         @default(now())

  @@index([userId])
  @@index([vendorId])
  @@index([actionType])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}